  "actions": [
    {
      "action_id": "transcription_mrna_export",
      "display_name": "Transcription and mRNA Export",
      "priority": 1,
      "teaching_goal": "Show how an active gene inside the nucleus produces RNA, processes it into mRNA, and exports it through a selective nuclear pore without implying that DNA leaves the nucleus.",
      "biological_scope": {
        "included": [
          "gene activation",
          "chromatin opening",
          "transcription initiation",
          "nascent RNA growth",
          "simplified mRNA processing",
          "mRNA export through nuclear pore complex",
          "handoff cue toward ribosomes or rough ER"
        ],
        "excluded_for_first_pass": [
          "base-pair-level molecular chemistry",
          "full spliceosome machinery",
          "complete transcription factor network",
          "codon-level translation",
          "all protein folding and Golgi processing steps"
        ],
        "misconceptions_to_avoid": [
          "DNA leaves the nucleus",
          "nuclear pores are passive open holes",
          "mRNA exits through the envelope anywhere other than a nuclear pore",
          "the nucleolus has a membrane",
          "translation happens inside the nucleus"
        ]
      },
